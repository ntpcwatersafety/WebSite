name = "ntpcwsa-cms-api"
main = "index.js"
compatibility_date = "2026-03-12"

[vars]
OWNER = "ntpcwatersafety"
REPO = "WebSite"
BRANCH = "main"
DATA_PATH = "public/cms-data.json"
JWT_EXPIRES_IN = "24h"

# 請改成你的正式網域，並在 Cloudflare dashboard 綁定相同路由
routes = [
  { pattern = "ntpcwsa.org/api/*", zone_name = "ntpcwsa.org" }
]

# 以下敏感資訊請用 Cloudflare secret 設定，不要直接寫在檔案內：
# wrangler secret put ADMIN_USER
# wrangler secret put ADMIN_PASS
# wrangler secret put JWT_SECRET
# wrangler secret put GITHUB_TOKEN